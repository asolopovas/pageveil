{
    "name": "asolopovas/pageveil",
    "description": "Veil your WordPress site with any chosen Gutenberg page.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": { "php": ">=8.1" },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "brain/monkey": "^2.6"
    },
    "autoload-dev": {
        "psr-4": { "Pageveil\\Tests\\": "tests/" }
    },
    "scripts": { "test": "phpunit" },
    "config": { "sort-packages": true, "allow-plugins": { "*": true } }
}
